# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def mergeTwoLists(self, list1: Optional[ListNode], list2: Optional[ListNode]) -> Optional[ListNode]:
        n1 = list1
        n2 = list2
        res = ListNode(0)
        node = res
        while n1 != None and n2 != None:
            if n1.val <= n2.val:
                node.next = n1
                n1 = n1.next
            else:
                node.next = n2
                n2 =n2.next
            node=node.next
        if n1:
            node.next = n1
        else:
            node.next = n2

        return res.next
        
